{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "strict_comparison": true,
        "strict_param": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "no_unused_imports": true,
        "concat_space": {
            "spacing": "none"
        },
        "phpdoc_align": {
            "align": "left"
        }
    },
    "exclude": [
        "vendor"
    ]
}
